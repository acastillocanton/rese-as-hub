# Public Supabase config (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase service role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Business Profile OAuth (server-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# Cron job protection
CRON_SECRET=generate-a-random-secret

# Resend (transactional email)
RESEND_API_KEY=

# App URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
